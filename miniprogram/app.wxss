page {
  min-height: 100%;
  background: #f6f8fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.muted {
  color: #64748b;
  line-height: 1.55;
}

.button {
  border-radius: 8rpx;
  background: #0f172a;
  color: #ffffff;
  font-weight: 600;
}

.button.secondary {
  background: #e2e8f0;
  color: #111827;
}

.panel {
  border: 1rpx solid #dbe3ee;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 28rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
