.result-page {
  gap: 32rpx;
}

.brand-mini {
  border: 2rpx solid #e7d7d2;
  border-radius: 8rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff6f3 100%);
  padding: 28rpx;
  box-sizing: border-box;
}

.brand-title {
  color: #191514;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.brand-line {
  color: #191514;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.45;
}

.date-nav {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-nav-button {
  width: 72rpx;
  height: 72rpx;
  min-height: 72rpx;
  border: 2rpx solid #e7d7d2;
  border-radius: 8rpx;
  background: #ffffff;
  color: #b91c1c;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 66rpx;
  padding: 0;
  box-shadow: none;
  flex-shrink: 0;
}

.date-nav-button.disabled {
  color: #a8a29e;
  background: #f3eee9;
}

.date-nav-button::after,
.today-jump::after {
  border: 0;
}

.date-picker {
  flex: 1;
  min-width: 0;
}

.date-picker-trigger {
  min-width: 0;
  min-height: 72rpx;
  border: 2rpx solid #e7d7d2;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 8rpx 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
}

.date-label {
  color: #191514;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.date-picker-hint {
  color: #5f6673;
  font-size: 22rpx;
  line-height: 1.2;
  margin-top: 4rpx;
}

.today-jump {
  align-self: flex-start;
  min-height: 56rpx;
  border: 2rpx solid #f3b4b8;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #b91c1c;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 56rpx;
  padding: 0 20rpx;
  margin: -8rpx 0 0;
}

.today-jump.disabled {
  color: #a8a29e;
  background: #f3eee9;
  border-color: #e7d7d2;
}

.talk-panel {
  border: 2rpx solid #f3b4b8;
  border-radius: 8rpx;
  background: #fff5f3;
  padding: 32rpx;
  box-sizing: border-box;
}

.talk-panel.talking {
  border-color: #e11d2e;
  background: #fff1f2;
}

.talk-time {
  color: #161616;
  font-size: 76rpx;
  font-weight: 700;
  line-height: 1.1;
  text-align: center;
}

.error-text {
  color: #b91c1c;
  font-size: 30rpx;
  line-height: 1.6;
}

.view-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.view-tab {
  min-height: 72rpx;
  border: 2rpx solid #e7d7d2;
  border-radius: 8rpx;
  background: #ffffff;
  color: #5f6673;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.view-tab.active {
  border-color: #e11d2e;
  background: #fff1f2;
  color: #b91c1c;
}

.view-tab::after {
  border: 0;
}

.result-intro {
  padding: 4rpx 0;
}

.category-card {
  border-left-width: 10rpx;
}

.category-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.category-count {
  flex-shrink: 0;
  color: #5f6673;
  font-size: 28rpx;
  font-weight: 700;
}

.category-line {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.timeline-entry + .timeline-entry {
  padding-top: 22rpx;
  border-top: 2rpx solid #f1e5e1;
}

.list-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #b91c1c;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 40rpx;
  text-align: center;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.line-main {
  flex: 1;
  min-width: 0;
}

.list-line {
  color: #2a2a2a;
  font-size: 34rpx;
  line-height: 1.65;
}

.line-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.small-primary,
.small-secondary,
.small-danger {
  flex: 1;
  min-height: 72rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.small-primary {
  background: #e11d2e;
  color: #ffffff;
}

.small-secondary {
  border: 2rpx solid #e7d7d2;
  background: #ffffff;
  color: #b91c1c;
}

.small-danger {
  border: 2rpx solid #fecaca;
  background: #fff1f2;
  color: #b91c1c;
}

.small-primary::after,
.small-secondary::after,
.small-danger::after {
  border: 0;
}

.edit-box {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #f3b4b8;
  border-radius: 8rpx;
  background: #fffafa;
  color: #191514;
  font-size: 34rpx;
  line-height: 1.6;
  padding: 18rpx;
  box-sizing: border-box;
}

.share-area {
  padding-bottom: env(safe-area-inset-bottom);
}

.weekly-note {
  border: 2rpx solid #e7d7d2;
  border-radius: 8rpx;
  background: #fff6f3;
  padding: 28rpx;
  box-sizing: border-box;
}

.weekly-note-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.weekly-dismiss {
  width: 56rpx;
  height: 56rpx;
  min-height: 56rpx;
  border: 2rpx solid #e7d7d2;
  border-radius: 8rpx;
  background: #ffffff;
  color: #5f6673;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 50rpx;
  padding: 0;
  flex-shrink: 0;
}

.weekly-dismiss::after,
.weekly-action::after {
  border: 0;
}

.weekly-action {
  align-self: flex-start;
  min-height: 78rpx;
  border: 2rpx solid #e11d2e;
  border-radius: 8rpx;
  background: #ffffff;
  color: #b91c1c;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 78rpx;
  padding: 0 28rpx;
}

.category-todo {
  border-left-color: #e11d2e;
}

.category-experiment {
  border-left-color: #f5c542;
}

.category-maitaishao {
  border-left-color: #d97706;
}

.category-reflection {
  border-left-color: #0f766e;
}

.category-earning,
.category-learning,
.category-family,
.category-relaxing {
  border-left-color: #e7d7d2;
}
