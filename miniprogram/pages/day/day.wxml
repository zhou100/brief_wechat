<view class="page stack">
  <view class="stack">
    <text class="title">整理好了</text>
    <text class="muted">{{createdAt}}</text>
  </view>

  <view class="panel stack">
    <text class="section-title">Summary</text>
    <text wx:if="{{summary}}">{{summary}}</text>
    <text wx:else class="muted">还没有结果。</text>
  </view>

  <view class="panel stack">
    <text class="section-title">Key points</text>
    <block wx:for="{{keyPoints}}" wx:key="*this">
      <text class="list-line">- {{item}}</text>
    </block>
    <text wx:if="{{keyPoints.length === 0}}" class="muted">暂无关键点。</text>
  </view>

  <view class="panel stack">
    <text class="section-title">Open loops</text>
    <block wx:for="{{openLoops}}" wx:key="*this">
      <text class="list-line">- {{item}}</text>
    </block>
    <text wx:if="{{openLoops.length === 0}}" class="muted">没有未闭环事项。</text>
  </view>

  <button class="button" open-type="share" bindtap="prepareShare">分享摘要卡片</button>
  <button class="button secondary" bindtap="regenerate">重新生成</button>
  <button class="button danger" bindtap="deleteCurrent">删除这条内容</button>
  <button class="button secondary" bindtap="recordMore">再录一条</button>
</view>
