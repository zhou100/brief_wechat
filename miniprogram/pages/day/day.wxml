<view class="page page-shell stack result-page">
  <view class="stack">
    <text class="red-stamp">{{processing ? '正在记' : '今日'}}</text>
    <text class="title">今日清爽</text>
    <view class="date-nav">
      <button
        class="date-nav-button {{dateNavDisabled ? 'disabled' : ''}}"
        aria-label="前一天"
        disabled="{{dateNavDisabled}}"
        bindtap="goPreviousDay"
      >‹</button>
      <picker
        class="date-picker"
        mode="date"
        value="{{date}}"
        end="{{today}}"
        disabled="{{dateNavDisabled}}"
        bindchange="selectDate"
      >
        <view class="date-picker-trigger">
          <text class="date-label">{{dateLabel}}</text>
          <text class="date-picker-hint">点一下选日期</text>
        </view>
      </picker>
      <button
        class="date-nav-button {{isToday || dateNavDisabled ? 'disabled' : ''}}"
        aria-label="后一天"
        disabled="{{isToday || dateNavDisabled}}"
        bindtap="goNextDay"
      >›</button>
    </view>
    <button wx:if="{{!isToday}}" class="today-jump {{dateNavDisabled ? 'disabled' : ''}}" disabled="{{dateNavDisabled}}" bindtap="goToday">回到今天</button>
    <text class="muted">{{dayStatsText}}</text>
  </view>

  <view wx:if="{{entryCount == 0 && !recording && !starting && !stopping && !uploading && !processing}}" class="brand-mini stack">
    <text class="red-stamp">方言小记</text>
    <text class="brand-title">讲过先记下</text>
    <text class="brand-line">先把原话留住，需要时再理清爽。</text>
    <text class="helper-text">普通话、吴语、带口音都可以。</text>
  </view>

  <view class="talk-panel stack {{recording ? 'talking' : ''}}">
    <text class="section-title">{{recording ? '正在听你讲' : '想到什么就讲两句'}}</text>
    <text class="talk-time">{{elapsedLabel}}</text>
    <button wx:if="{{!starting && !recording && !stopping && !uploading && !processing}}" class="{{hasUntidiedTranscripts ? 'secondary-action' : 'primary-action'}}" bindtap="startRecord">开始讲</button>
    <button wx:elif="{{recording}}" class="primary-action" bindtap="stopRecord">讲好了，先记下来</button>
    <button wx:else class="primary-action" loading="true" disabled="true">正在记下来</button>
    <text wx:if="{{statusText}}" class="helper-text">{{statusText}}</text>
    <text wx:if="{{errorText}}" class="error-text">{{errorText}}</text>
  </view>

  <view wx:if="{{entryCount > 0 && !processing}}" class="tidy-panel stack">
    <view class="result-intro-row">
      <view class="stack tidy-copy">
        <text class="section-title">{{hasUntidiedTranscripts ? '先记下来了' : '想重新分一下？'}}</text>
        <text class="muted">{{hasUntidiedTranscripts ? '先看下面的原话；改好了，再点一下分门别类。' : '原话改过，或者觉得分类不对时，可以再整理一遍。'}}</text>
      </view>
      <button class="tidy-btn {{tidying ? 'disabled' : ''}}" loading="{{tidying}}" disabled="{{tidying}}" bindtap="tidy">{{hasUntidiedTranscripts ? '一键理清爽' : '重新整理'}}</button>
    </view>
  </view>

  <view wx:if="{{categoryGroups.length > 0 && entries.length > 0}}" class="view-tabs">
    <button class="view-tab {{viewMode === 'category' ? 'active' : ''}}" bindtap="showCategoryView">按分类看</button>
    <button class="view-tab {{viewMode === 'timeline' ? 'active' : ''}}" bindtap="showTimelineView">记下的原话</button>
  </view>

  <view wx:if="{{viewMode === 'category' && categoryGroups.length > 0}}" class="stack">
    <view class="result-intro stack">
      <text class="section-title">整理好了</text>
      <text class="muted">已做的归档，还要做的单独放。</text>
    </view>
    <block wx:for="{{categoryGroups}}" wx:key="category" wx:for-item="group">
      <view class="panel stack category-card {{group.accentClass}}">
        <view class="category-heading">
          <text class="section-title">{{group.label}}</text>
          <text class="category-count">{{group.items.length}} 条</text>
        </view>
        <text wx:if="{{group.helper}}" class="muted">{{group.helper}}</text>
        <block wx:for="{{group.items}}" wx:key="id" wx:for-item="thing" wx:for-index="thingIndex">
          <view class="category-line">
            <text class="list-index">{{thingIndex + 1}}</text>
            <view class="line-main">
              <block wx:if="{{editingItemId == thing.id}}">
                <textarea
                  class="edit-box"
                  value="{{editDraft}}"
                  auto-focus="true"
                  auto-height="true"
                  maxlength="300"
                  bindinput="updateEditDraft"
                />
                <view class="line-actions">
                  <button class="small-primary" data-item-id="{{thing.id}}" bindtap="saveEdit">存好</button>
                  <button class="small-secondary" bindtap="cancelEdit">算了</button>
                </view>
              </block>
              <block wx:else>
                <text class="list-line">{{thing.text}}</text>
                <view wx:if="{{thing.id}}" class="line-actions">
                  <button class="small-secondary" data-item-id="{{thing.id}}" data-text="{{thing.text}}" bindtap="startEdit">改一下</button>
                  <button class="small-danger" data-item-id="{{thing.id}}" bindtap="deleteThing">删除</button>
                </view>
              </block>
            </view>
          </view>
        </block>
      </view>
    </block>
  </view>

  <view wx:elif="{{viewMode === 'timeline' && entries.length > 0}}" class="panel stack">
    <text class="section-title">记下的原话</text>
    <text class="muted">{{hasUntidiedTranscripts ? '先核对原话；点上面的“一键理清爽”后，我再帮你分门别类。' : '这里尽量保留原来的转写，方便你校对和回想。'}}</text>
    <block wx:for="{{entries}}" wx:key="id" wx:for-item="entry" wx:for-index="entryIndex">
      <view class="category-line timeline-entry">
        <text class="list-index">{{entryIndex + 1}}</text>
        <view class="line-main">
          <block wx:if="{{editingEntryId == entry.id}}">
            <textarea
              class="edit-box"
              value="{{entryEditDraft}}"
              auto-focus="true"
              auto-height="true"
              maxlength="1000"
              bindinput="updateEntryEditDraft"
            />
            <view class="line-actions">
              <button class="small-primary" data-entry-id="{{entry.id}}" bindtap="saveEntryEdit">存好</button>
              <button class="small-secondary" bindtap="cancelEntryEdit">算了</button>
            </view>
          </block>
          <block wx:else>
            <text class="list-line">{{entry.transcript || '这段没有转写出来'}}</text>
            <view wx:if="{{entry.id}}" class="line-actions">
              <button class="small-secondary" data-entry-id="{{entry.id}}" data-transcript="{{entry.transcript}}" bindtap="startEntryEdit">改一下</button>
              <button class="small-danger" data-entry-id="{{entry.id}}" bindtap="deleteEntryTranscript">删除</button>
            </view>
          </block>
        </view>
      </view>
    </block>
  </view>

  <view wx:else class="panel stack">
    <text class="section-title">{{dateLabel}}还空着</text>
    <text class="muted">讲一段以后，先看到原话；需要时再按“办事体、买汰烧、照顾家人、还要做”等分类放好。</text>
  </view>

  <view wx:if="{{weeklySuggestion}}" class="weekly-note stack">
    <view class="weekly-note-top">
      <text class="red-stamp">上个礼拜</text>
      <button class="weekly-dismiss" aria-label="这礼拜不提醒" bindtap="dismissWeeklyThings">×</button>
    </view>
    <text class="section-title">要不要理一理上个礼拜的事体？</text>
    <text class="muted">我帮你把讲过的话放在一张纸上。</text>
    <button class="weekly-action" bindtap="openWeeklyThings">帮我理一理</button>
  </view>

</view>
