<view class="page page-shell stack job-page">
  <view class="panel paper-panel stack job-card">
    <text class="red-stamp">{{failed ? '没记好' : '正在记'}}</text>
    <text class="title">{{failed ? '这段没听清' : '正在把原话记下来'}}</text>
    <text class="muted">{{stepText}}</text>
    <progress percent="{{progress}}" stroke-width="6" active activeColor="#E11D2E" backgroundColor="#F7DDD8" />
  </view>

  <view wx:if="{{preview}}" class="panel stack">
    <text class="section-title">先看到一句</text>
    <text>{{preview}}</text>
  </view>

  <view wx:if="{{errorMessage}}" class="panel stack">
    <text class="section-title">回到今天再讲</text>
    <text>{{errorMessage}}</text>
  </view>

  <view class="bottom-actions">
    <button wx:if="{{failed}}" class="primary-action" bindtap="goRecord">回今日清爽</button>
    <button class="secondary-action" bindtap="goHome">回到今天</button>
  </view>
</view>
