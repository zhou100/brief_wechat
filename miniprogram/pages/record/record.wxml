<view class="page page-shell stack record-page">
  <view class="record-face {{recording ? 'active' : ''}}">
    <text class="red-stamp">{{recording ? '正在讲' : '准备好了'}}</text>
    <text class="record-time">{{elapsedLabel}}</text>
    <text class="record-status">{{statusText}}</text>
  </view>

  <view class="bottom-actions">
    <button wx:if="{{!recording && !uploading}}" class="primary-action" bindtap="start">开始讲</button>
    <button wx:elif="{{recording}}" class="primary-action" bindtap="stop">讲好了，先记下来</button>
    <button wx:else class="secondary-action" loading="true">正在记下来</button>

    <button wx:if="{{lastFilePath && !uploading}}" class="secondary-action" bindtap="retryUpload">重试上传</button>
  </view>

  <view wx:if="{{showPresetPicker && !recording && !uploading}}" class="panel stack">
    <text class="section-title">录音格式测试</text>
    <picker mode="selector" range="{{presetLabels}}" value="{{selectedPresetIndex}}" bindchange="changePreset">
      <view class="preset-picker">{{selectedPresetLabel}}</view>
    </picker>
    <text class="muted">换一个格式后直接重新录 5 秒测试，不需要重新编译。</text>
  </view>

  <view wx:if="{{errorText}}" class="panel stack">
    <text class="section-title">这段没传上去</text>
    <text>{{errorText}}</text>
  </view>

  <view class="panel qing-note">
    <text class="helper-text">不需要想格式，像平时讲话一样。录完后先保留原话，需要时再理清爽。</text>
  </view>
</view>
