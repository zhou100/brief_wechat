.record-face {
  height: 420rpx;
  border: 1rpx solid #dbe3ee;
  border-radius: 8rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.record-face.active {
  border-color: #ef4444;
}

.record-time {
  font-size: 72rpx;
  font-weight: 700;
}

.preset-picker {
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  color: #0f172a;
  background: #f8fafc;
}
