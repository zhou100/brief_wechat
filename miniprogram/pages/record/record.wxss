.record-page {
  gap: 32rpx;
}

.record-face {
  min-height: 520rpx;
  border: 2rpx solid #e7d7d2;
  border-radius: 24rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 40rpx 28rpx;
  box-sizing: border-box;
}

.record-face.active {
  border-color: #e11d2e;
  background: #fff6f3;
}

.record-time {
  color: #161616;
  font-size: 96rpx;
  font-weight: 700;
  line-height: 1.1;
}

.record-status {
  color: #5f6673;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.5;
}

.preset-picker {
  border: 2rpx solid #e7d7d2;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  color: #191514;
  background: #ffffff;
}
