ENVIRONMENT=production
LOG_LEVEL=INFO
PORT=10000

DATABASE_URL=mysql+aiomysql://USER:PASSWORD@HOST:3306/DBNAME?charset=utf8mb4
SECRET_KEY=replace-with-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=240

WECHAT_APPID=replace-with-mini-program-appid
WECHAT_SECRET=replace-with-mini-program-appsecret
MINIAPP_PUBLIC_BASE_URL=https://replace-with-cloudbase-run-domain
USE_CLOUDBASE_STORAGE=true

OPENAI_API_KEY=replace-with-openai-key

ALLOWED_ORIGINS_STR=*
